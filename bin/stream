#!/bin/bash

TWITCH=('aypierre' 'b1gmaw' 'bichard' 'cass_andre' 'chuckow' 'danyetraz' 'discordinsoumis' 'dokhy' 'imsofresh' 'jeanmassiet' 'lege' 'lord_tinen' 'magarky' 'malm' 'mouffette_' 'nenu' 'ostpolitik' 'pasdebol_tft' 'shaunz' 'softstyl' 'theguill84' 'un33d' 'usul2000' 'voltariux' 'zerator' 'zozote')
FRANCETV=('france-2' 'france-3' 'france-4' 'france-5')

twitchchannels=""
francetvchannels=""

for channel in "${TWITCH[@]}";
do
	twitchchannels+="$channel\n"
done

for channel in "${FRANCETV[@]}";
do
	francetvchannels+="$channel\n"
done

platform=$(echo -e "twitch\nfrancetv" | dmenu -fn 'JetBrainsMono Nerd Font-14' -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#313244' -nhb '#1e1e2e' -nhf '#cba6f7' -shb '#cba6f7' -shf '#11111b')

if [ $platform = "twitch" ];
then
	live=$(echo -e $twitchchannels | dmenu -fn 'JetBrainsMono Nerd Font-14' -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#313244' -nhb '#1e1e2e' -nhf '#cba6f7' -shb '#cba6f7' -shf '#11111b')
	#chatterino --channels t:$live &
	live="https://twitch.tv/$live"
elif [ $platform = "francetv" ];
then
	live="https://www.france.tv/"
	live+=$(echo -e $francetvchannels | dmenu -fn 'JetBrainsMono Nerd Font-14' -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#313244' -nhb '#1e1e2e' -nhf '#cba6f7' -shb '#cba6f7' -shf '#11111b')
	live+="/direct.html" 
else
	live=$platform
fi

quality=$(streamlink $live)

if [[ $quality = *"Available streams"* ]];
then
	quality=${quality/#*"streams: "}
	quality=${quality//"(worst)"}
	quality=${quality//"(best)"}
	quality=${quality//,/"\n"}

    quality=$(echo -e $quality | dmenu -fn 'JetBrainsMono Nerd Font-14' -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#313244' -nhb '#1e1e2e' -nhf '#cba6f7' -shb '#cba6f7' -shf '#11111b')

	streamlink $live $quality
else
    $(echo -e "stream offline" | dmenu -fn 'JetBrainMono Nerd Font-14' -nb '#f2cdcd' -nf '#f38ba8' -sb '#f2cdcd' -sf '#f38ba8' -nhb '#f2cdcd' -nhf '#f38ba8' -shb '#f2cdcd' -shf '#f38ba8')
fi
