#!/bin/bash

TWITCH=('aypierre' 'b1gmaw' 'bichard' 'cass_andre' 'chuckow' 'danyetraz' 'discordinsoumis' 'dokhy' 'imsofresh' 'jeanmassiet' 'lege' 'lord_tinen' 'magarky' 'malm' 'mouffette_' 'nenu' 'ostpolitik' 'pasdebol_tft' 'shaunz' 'softstyl' 'theguill84' 'un33d' 'usul2000' 'voltariux' 'zerator' 'zozote')
FRANCETV=('france-2' 'france-3' 'france-4' 'france-5')

twitchchannels=""
francetvchannels=""

for channel in "${TWITCH[@]}";
do
	twitchchannels+="$channel\n"
done

for channel in "${FRANCETV[@]}";
do
	francetvchannels+="$channel\n"
done

platform=$(echo -e "twitch\nfrancetv" | dmenu -fn 'Fira Code Nerd Font-14' -nb '#1e2127' -nf '#abb2bf' -sb '#98c379' -nhb '#1e2127' -nhf '#c678dd' -shb '#98c379' -shf '#c678dd')

if [ $platform = "twitch" ];
then
	live=$(echo -e $twitchchannels | dmenu -fn 'Fira Code Nerd Font-14' -nb '#1e2127' -nf '#abb2bf' -sb '#98c379' -nhb '#1e2127' -nhf '#c678dd' -shb '#98c379' -shf '#c678dd')
	#chatterino --channels t:$live &
	live="https://twitch.tv/$live"
elif [ $platform = "francetv" ];
then
	live="https://www.france.tv/"
	live+=$(echo -e $francetvchannels | dmenu -fn 'Fira Code Nerd Font-14' -nb '#1e2127' -nf '#abb2bf' -sb '#98c379' -nhb '#1e2127' -nhf '#c678dd' -shb '#98c379' -shf '#c678dd')
	live+="/direct.html" 
else
	live=$platform
fi

quality=$(streamlink $live)

if [[ $quality = *"Available streams"* ]];
then
	quality=${quality/#*"streams: "}
	quality=${quality//"(worst)"}
	quality=${quality//"(best)"}
	quality=${quality//,/"\n"}

	quality=$(echo -e $quality | dmenu -fn 'Fira Code Nerd Font-14' -nb '#1e2127' -nf '#abb2bf' -sb '#98c379' -nhb '#1e2127' -nhf '#c678dd' -shb '#98c379' -shf '#c678dd')

	streamlink $live $quality
else
	$(echo -e "stream offline" | dmenu -fn 'Fira Code Nerd Font-14' -nb '#bf404a' -nf '#e06c75' -sb '#bf404a' -nhb '#bf404a' -nhf '#e06c75' -shb '#bf404a' -shf '#e06c75')
fi
