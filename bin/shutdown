#!/bin/bash

option=$(echo -e "shutdown\nreboot\nlock" | dmenu -l 20 -fn 'JetBrainsMono Nerd Font-14' -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#313244' -nhb '#1e1e2e' -nhf '#cba6f7' -shb '#cba6f7' -shf '#11111b')

if [ $option = "shutdown" ];
then
    shutdown now
elif [ $option = "reboot" ];
then
    reboot now
elif [ $option = "lock" ];
then
    betterlockscreen -l blur
else
    echo 0
fi
