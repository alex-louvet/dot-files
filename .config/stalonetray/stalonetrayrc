# stalonetray config used by Vic Fryzel
# Author: Vic Fryzel
# https://github.com/vicfryzel/xmonad-config


# This stalonetrayrc is meant to match with xmobar-single.hs. If you use both,
# then you'll get a perfect setup on a single 4k display (3840x2160). If you
# have dual monitors, see stalonetrayrc-dual and xmobar-dual.hs.

# If you're using a single display with a different resolution, adjust the
# geometry below using the given calculation.

# 1 row of 8 icons, each 23px wide/tall. Resolution 2560x1440.
# This icon size aligns with the size of xmobar with font "xft:monospace-8"
# position = display_width - (num_icons * icon_size)
# position = 2560 - (8 * 28) = 2336
# Example: geometry 8x1+3564
geometry 10x1+2280
icon_size 28
sticky 1
window_type dock
dockapp_mode wmaker
window_strut auto
skip_taskbar 1
icon_gravity NW
background "#2E323A"
kludges force_icons_size
